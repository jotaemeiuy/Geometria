---
import type { Section } from "../../data/courseData";
import CourseItem from "./CourseItem.astro";

interface Props {
  section: Section;
  index: number;
}

const { section, index } = Astro.props;
const delayClass = `animate-delay-${Math.min(index + 1, 6)}`;
---

<section
  class={`p-6 rounded-xl bg-white/2 border border-white/10 animate-fade-in-up ${delayClass}`}
>
  <div class="flex items-center gap-3 mb-2">
    <span class="text-blue-400 font-mono text-sm font-semibold"
      >{section.number}</span
    >
    <h2 class="text-xl font-bold text-white">{section.title}</h2>
  </div>

  <div class="flex items-center justify-between gap-3 mb-5">
    <p class="text-white/50 text-sm">{section.description}</p>
    <span class="rounded-full bg-white/5 px-3 py-1 text-xs text-white/60"
      >{section.lessons.length} lecciones</span
    >
  </div>

  <div class="flex flex-col gap-1">
    {
      section.lessons.map((lesson) => (
        <CourseItem
          sectionSlug={section.slug}
          title={lesson.title}
          slug={lesson.slug}
        />
      ))
    }
  </div>
</section>
