---
---

<div id="celebration-overlay" class="fixed inset-0 pointer-events-none z-50 hidden items-center justify-center">
  <div class="absolute inset-0 bg-emerald-500/5 transition-opacity duration-500" id="celebration-bg"></div>
  <div class="relative transform scale-0 transition-all duration-500" id="celebration-content">
    <div class="bg-slate-900/95 border border-emerald-500/30 rounded-2xl px-8 py-6 shadow-2xl shadow-emerald-500/20 text-center">
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-emerald-500/20 flex items-center justify-center">
        <svg class="w-8 h-8 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M20 6L9 17l-5-5"/>
        </svg>
      </div>
      <h3 class="text-xl font-bold text-white mb-2">¡Lección completada!</h3>
      <p class="text-white/60 text-sm mb-3">Sigue así, vas avanzando muy bien.</p>
      <div class="inline-flex items-center gap-2 bg-emerald-500/10 rounded-full px-4 py-1.5">
        <span class="text-emerald-400 font-semibold text-sm" id="celebration-percent">0%</span>
        <span class="text-white/50 text-xs">del curso</span>
      </div>
    </div>
  </div>
  
  <!-- Confetti elements -->
  <div id="confetti-container" class="absolute inset-0 overflow-hidden pointer-events-none"></div>
</div>

<script>
  import { getProgressPercentage } from '../../utils/progress';
  import { courseData } from '../../data/courseData';

  const totalLessons = courseData.reduce((acc, section) => acc + section.lessons.length, 0);

  export function showCelebration() {
    const overlay = document.getElementById('celebration-overlay');
    const content = document.getElementById('celebration-content');
    const bg = document.getElementById('celebration-bg');
    const percentText = document.getElementById('celebration-percent');
    const confettiContainer = document.getElementById('confetti-container');

    if (!overlay || !content || !bg || !percentText || !confettiContainer) return;

    // Actualizar porcentaje
    const percentage = getProgressPercentage(totalLessons);
    percentText.textContent = `${percentage}%`;

    // Mostrar overlay
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');

    // Animar entrada
    setTimeout(() => {
      bg.classList.remove('opacity-0');
      content.classList.remove('scale-0');
      content.classList.add('scale-100');
    }, 10);

    // Crear confetti
    createConfetti(confettiContainer);

    // Ocultar después de 2.5 segundos
    setTimeout(() => {
      content.classList.remove('scale-100');
      content.classList.add('scale-0');
      bg.classList.add('opacity-0');

      setTimeout(() => {
        overlay.classList.add('hidden');
        overlay.classList.remove('flex');
        confettiContainer.innerHTML = '';
      }, 500);
    }, 2500);
  }

  function createConfetti(container: HTMLElement) {
    const colors = ['#34d399', '#60a5fa', '#f472b6', '#fbbf24', '#a78bfa'];
    
    for (let i = 0; i < 30; i++) {
      const confetti = document.createElement('div');
      const color = colors[Math.floor(Math.random() * colors.length)];
      const left = Math.random() * 100;
      const delay = Math.random() * 0.5;
      const duration = 1 + Math.random() * 1;

      confetti.style.cssText = `
        position: absolute;
        width: ${8 + Math.random() * 8}px;
        height: ${8 + Math.random() * 8}px;
        background: ${color};
        left: ${left}%;
        top: -20px;
        border-radius: ${Math.random() > 0.5 ? '50%' : '2px'};
        animation: confetti-fall ${duration}s ease-out ${delay}s forwards;
        opacity: 0.8;
      `;

      container.appendChild(confetti);
    }
  }
</script>

<style>
  @keyframes confetti-fall {
    0% {
      transform: translateY(-20px) rotate(0deg);
      opacity: 1;
    }
    100% {
      transform: translateY(100vh) rotate(720deg);
      opacity: 0;
    }
  }
</style>
