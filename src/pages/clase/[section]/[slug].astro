---
import Celebration from "../../../components/course/Celebration.astro";
import LessonNavigation from "../../../components/course/LessonNavigation.astro";
import ProgressTracker from "../../../components/course/ProgressTracker.astro";
import { courseData, getAdjacentLessons } from "../../../data/courseData";
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../sections/Header.astro";

export function getStaticPaths() {
  const paths: {
    params: { section: string; slug: string };
    props: { lesson: any; section: any };
  }[] = [];

  courseData.forEach((section) => {
    section.lessons.forEach((lesson) => {
      paths.push({
        params: { section: section.slug, slug: lesson.slug },
        props: { lesson, section },
      });
    });
  });

  return paths;
}

const sectionSlug = Astro.params.section;
const slug = Astro.params.slug;
const { lesson, section } = Astro.props;
const { prev, next } = getAdjacentLessons(sectionSlug, slug);
const lessonIndex = section.lessons.findIndex(
  (item: { slug: string }) => item.slug === slug,
);
const lessonNumber = lessonIndex + 1;
const totalLessons = section.lessons.length;
const progressWidth = Math.round((lessonNumber / totalLessons) * 100);
---

<Layout title={`${lesson.title} | Aprende p5.js`}>
  <Header />

  <main class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid gap-10 lg:grid-cols-[220px_minmax(0,1fr)]">
      <aside class="hidden lg:block" data-section-slug={sectionSlug}>
        <div
          class="sticky top-24 rounded-4xl border border-white/8 bg-white/3 p-6 shadow-[0_20px_70px_rgba(15,23,42,0.35)]"
        >
          <div class="mb-5">
            <div class="flex items-center justify-between mb-2">
              <p class="text-xs uppercase tracking-[0.3em] text-white/40">
                Progreso
              </p>
              {
                progressWidth === 100 ? (
                  <span class="inline-flex items-center gap-1 text-xs font-medium text-emerald-400">
                    <svg
                      class="w-3.5 h-3.5"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path d="M20 6L9 17l-5-5" />
                    </svg>
                    Completado
                  </span>
                ) : (
                  <span class="text-xs font-medium text-blue-300">
                    {progressWidth}%
                  </span>
                )
              }
            </div>
            <div class="h-1 w-full rounded-full bg-white/10 overflow-hidden">
              <div
                class="h-full rounded-full bg-linear-to-r from-blue-400 via-sky-400 to-cyan-300 transition-all duration-500"
                style={`width: ${progressWidth}%`}
              >
              </div>
            </div>
          </div>

          <div class="border-t border-white/8 pt-4">
            <p class="text-xs uppercase tracking-[0.3em] text-white/40 mb-1">
              Sección {section.number}
            </p>
            <h2 class="text-lg font-semibold text-white mb-1">
              {section.title}
            </h2>
            <p class="text-sm text-white/50">
              Lección {lessonNumber} de {totalLessons}
            </p>
          </div>

          <div class="border-t border-white/8 pt-4 mt-4">
            <p class="text-xs uppercase tracking-[0.2em] text-white/40 mb-3">
              Lecciones de esta sección
            </p>
            <ul class="space-y-1.5" id="sidebar-lessons">
              {
                section.lessons.map(
                  (l: { slug: string; title: string }, index: number) => (
                    <li>
                      <a
                        href={`/clase/${section.slug}/${l.slug}`}
                        class={`flex items-center gap-2 py-1.5 px-2 rounded-md text-sm transition-all duration-200 ${
                          l.slug === slug
                            ? "bg-blue-500/20 text-blue-300 border border-blue-500/30"
                            : "text-white/60 hover:bg-white/5 hover:text-white/80"
                        }`}
                        data-lesson-slug={l.slug}
                      >
                        <span class="text-xs text-white/30 w-4">
                          {index + 1}
                        </span>
                        <span class="flex-1 truncate">{l.title}</span>
                        <svg
                          class="w-3.5 h-3.5 text-emerald-400 hidden lesson-check"
                          data-check-slug={l.slug}
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <path d="M20 6L9 17l-5-5" />
                        </svg>
                      </a>
                    </li>
                  ),
                )
              }
            </ul>
          </div>
        </div>
      </aside>

      <div>
        <header class="mb-8">
          <a
            href="/"
            class="inline-flex items-center gap-1.5 text-blue-400/60 text-sm hover:text-blue-400 transition-colors mb-4"
          >
            <svg
              class="w-4 h-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
            Volver al curso
          </a>

          <div class="mb-4 rounded-3xl border border-white/8 bg-white/3 p-4">
            <div
              class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
            >
              <div class="text-sm text-white/60">
                Sección {section.number} · {section.title}
              </div>
              <div class="text-sm font-medium text-white">
                Lección {lessonNumber} de {totalLessons}
              </div>
            </div>
          </div>

          <div class="flex items-center gap-2 text-sm text-white/40 mb-2">
            <span>{section.number}</span>
            <span>·</span>
            <span>{section.title}</span>
          </div>

          <h1 class="text-3xl md:text-4xl font-bold text-white">
            {lesson.title}
          </h1>
          <p class="mt-4 text-white/60 max-w-2xl">
            Esta lección te guía con ejemplos claros y ejercicios cortos para
            aprender paso a paso. Lee con atención y prueba los cambios en tu
            sketch.
          </p>
        </header>

        <article
          class="prose prose-invert prose-blue max-w-none
          prose-headings:text-white prose-headings:font-bold
          prose-h2:text-2xl prose-h2:mt-8 prose-h2:mb-4
          prose-p:text-white/70 prose-p:leading-relaxed
          prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline
          prose-code:bg-white/6 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-blue-300
          prose-pre:bg-white/3 prose-pre:border prose-pre:border-white/6 prose-pre:rounded-lg
          prose-ul:text-white/70 prose-ol:text-white/70"
        >
          <Fragment set:html={lesson.content} />
        </article>

        <ProgressTracker sectionSlug={sectionSlug} lessonSlug={slug} />

        <LessonNavigation prev={prev} next={next} />
      </div>
    </div>
  </main>
</Layout>

<script>
  import { isLessonCompleted, getProgress } from "../../../utils/progress";

  const sectionSlug =
    document
      .querySelector("[data-section-slug]")
      ?.getAttribute("data-section-slug") ||
    window.location.pathname.split("/")[2];

  function updateSidebarChecks() {
    const checkIcons = document.querySelectorAll(".lesson-check");
    checkIcons.forEach((icon) => {
      const lessonSlug = icon.getAttribute("data-check-slug");
      if (lessonSlug && isLessonCompleted(sectionSlug, lessonSlug)) {
        icon.classList.remove("hidden");
      } else {
        icon.classList.add("hidden");
      }
    });
  }

  function updateSectionProgress() {
    const progress = getProgress();
    const sectionLessons = document.querySelectorAll("[data-check-slug]");
    const totalSectionLessons = sectionLessons.length;

    let completedSectionLessons = 0;
    sectionLessons.forEach((el) => {
      const lessonSlug = el.getAttribute("data-check-slug");
      if (lessonSlug && isLessonCompleted(sectionSlug, lessonSlug)) {
        completedSectionLessons++;
      }
    });

    const sectionProgress =
      totalSectionLessons > 0
        ? Math.round((completedSectionLessons / totalSectionLessons) * 100)
        : 0;

    // Actualizar barra de progreso de la sección
    const progressBar = document.querySelector(".h-full.rounded-full");
    const progressText = document.querySelector(
      ".text-xs.font-medium.text-blue-300",
    );
    const completedBadge = document.querySelector(
      ".text-xs.font-medium.text-emerald-400",
    );

    if (progressBar) {
      (progressBar as HTMLElement).style.width = `${sectionProgress}%`;
    }
    if (progressText) {
      progressText.textContent = `${sectionProgress}%`;
    }

    // Mostrar "Completado" si todas las lecciones de la sección están listas
    if (
      sectionProgress === 100 &&
      progressText &&
      completedBadge?.parentElement
    ) {
      progressText.parentElement?.classList.add("hidden");
      completedBadge.parentElement?.classList.remove("hidden");
    }
  }

  // Actualizar al cargar
  updateSidebarChecks();
  updateSectionProgress();

  // Actualizar cuando se dispare el evento de progreso actualizado
  window.addEventListener("progress-updated", () => {
    updateSidebarChecks();
    updateSectionProgress();
  });
</script>
