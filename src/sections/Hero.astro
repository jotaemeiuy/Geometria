---
import { courseData } from "../data/courseData";

const firstSection = courseData[0];
const firstLesson = firstSection?.lessons?.[0];
const firstLessonUrl = firstLesson
  ? `/clase/${firstSection.slug}/${firstLesson.slug}`
  : "/";
---

<div
  class="flex flex-col items-center justify-center text-center px-6 pt-12 pb-4"
>
  <h1
    class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white tracking-tight font-(family-name:--font-display) leading-[1.1] mb-5"
  >
    Aprende p5.js<br />
    <span class="text-blue-400">desde cero.</span>
  </h1>

  <p
    class="text-base md:text-lg text-white/45 leading-relaxed max-w-3xl mx-auto mb-4"
  >
    Curso pensado para aprender geometría, dibujo y programación visual con
    ejercicios prácticos y ejemplos claros.
  </p>

  <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mt-6">
    <a
      href={firstLessonUrl}
      class="inline-flex items-center justify-center rounded-full bg-blue-400 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-blue-400/20 hover:bg-blue-300 transition-all"
    >
      Comenzar el curso
    </a>
    <a
      href="#contenido"
      class="inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 px-6 py-3 text-sm font-semibold text-white/90 hover:bg-white/10 transition-all"
    >
      Ver contenido
    </a>
  </div>
</div>

<div class="flex flex-wrap justify-center gap-3 mt-8">
  <span
    class="inline-flex items-center gap-2 text-xs text-white/70 bg-white/4 border border-white/8 rounded-full px-3 py-2"
  >
    <strong class="text-blue-300">11</strong> lecciones
  </span>
  <span
    class="inline-flex items-center gap-2 text-xs text-white/70 bg-white/4 border border-white/8 rounded-full px-3 py-2"
  >
    <strong class="text-blue-300">70%</strong> práctico
  </span>
  <span
    class="inline-flex items-center gap-2 text-xs text-white/70 bg-white/4 border border-white/8 rounded-full px-3 py-2"
  >
    <strong class="text-blue-300">100%</strong> accesible
  </span>
</div>
